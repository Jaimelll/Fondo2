# Copia este archivo a .env.local (desarrollo) o .env (Docker) y completa los valores.
# Ninguna variable de Supabase aplica en fondo2 — todo corre sobre Postgres propio.

# Postgres
# - Desde el host (npm run dev sin Docker): usa localhost:5434 (puerto mapeado en docker-compose.yml)
# - Desde el contenedor "app" (docker compose up): usa el host interno "db" en el puerto 5432
DATABASE_URL=postgresql://fondo2:fondo2@localhost:5434/fondo2

# Auth (Better-Auth)
# BETTER_AUTH_SECRET: genera uno propio, ej. `openssl rand -base64 32`. No reutilices este placeholder.
BETTER_AUTH_SECRET=reemplaza-esto-con-un-secreto-generado
BETTER_AUTH_URL=http://localhost:8082

# Storage de PDFs (módulo Documentos Corporativos)
# Ruta dentro del contenedor/host donde se guardan los archivos subidos.
STORAGE_DOCUMENTS_PATH=./storage/documentos

# App
PORT=3000
HOSTNAME=0.0.0.0
